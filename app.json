{
  "expo": {
    "name": "NutriTrack 2.0",
    "slug": "nutritrack",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "nutritrack",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F0F0F0"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nutritrack.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "NutriTrack needs access to your microphone to record voice input for food logging.",
        "NSCameraUsageDescription": "NutriTrack needs access to your camera to scan food for nutrition analysis."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F0F0F0"
      },
      "package": "com.nutritrack.app",
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow NutriTrack to access your camera to scan food for nutrition analysis."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Allow NutriTrack to access your microphone for voice food logging."
        }
      ],
      "expo-web-browser"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1fd1d4cd-0de9-4fe1-9535-3713a4f23c48"
      }
    }
  }
}